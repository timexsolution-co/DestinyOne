{
  "name": "destinyone",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm test",
    "export:web": "expo export --platform web --output-dir dist",
    "build:web": "pnpm export:web",
    "release:check": "pnpm check && pnpm build:web"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo-google-fonts/satisfy": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@stripe/stripe-react-native": "0.64.0",
    "@supabase/supabase-js": "^2.58.0",
    "expo": "~55.0.0",
    "expo-audio": "~55.0.15",
    "expo-auth-session": "~55.0.17",
    "expo-font": "~55.0.4",
    "expo-image-picker": "~55.0.21",
    "expo-linear-gradient": "~55.0.3",
    "expo-location": "~55.1.11",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.17",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  }
}
