{
  "expo": {
    "name": "DestinyOne",
    "slug": "destinyone",
    "version": "1.0.0",
    "description": "Intentional dating for Indians in the USA, built for committed relationships and marriage.",
    "icon": "./assets/icon-red-velvet.png",
    "scheme": "destinyone",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "primaryColor": "#E5092F",
    "splash": {
      "image": "./assets/splash-red-velvet.png",
      "resizeMode": "contain",
      "backgroundColor": "#090002"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.destinyone.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.destinyone.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-red-velvet.png",
        "backgroundColor": "#090002"
      },
      "blockedPermissions": ["android.permission.ACCESS_FINE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon-red-velvet.png",
      "name": "DestinyOne",
      "shortName": "DestinyOne",
      "themeColor": "#090002",
      "backgroundColor": "#090002"
    },
    "plugins": [
      ["expo-image-picker", {
        "photosPermission": "DestinyOne needs photo access so you can build your relationship profile.",
        "cameraPermission": "DestinyOne uses the camera for profile photos and selfie verification."
      }],
      ["expo-audio", {
        "microphonePermission": "DestinyOne uses the microphone to record your optional voice introduction."
      }],
      ["expo-location", {
        "locationWhenInUsePermission": "DestinyOne uses approximate location only when you enable Crossed Paths. Your exact location is never shown to other members.",
        "isIosBackgroundLocationEnabled": false,
        "isAndroidBackgroundLocationEnabled": false
      }],
      ["@stripe/stripe-react-native", {
        "merchantIdentifier": "merchant.com.destinyone.app",
        "enableGooglePay": true
      }]
    ]
  }
}
